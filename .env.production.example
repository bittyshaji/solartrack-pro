# Production Environment Configuration Template
# Copy to .env.production and fill in actual values
# NEVER commit this file with real values

# ============================================
# SUPABASE CONFIGURATION (Production)
# ============================================
# These values come from Supabase Dashboard:
# Settings → API → Project URL and Keys

# Supabase project URL
VITE_SUPABASE_URL=https://your-prod-project.supabase.co

# Supabase anonymous key (for client-side auth)
# Use the anon/public key, NOT the service_role key
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InByb2plY3QtcmVmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM1NzU1MDgsImV4cCI6MjA4OTE1MTUwOH0.YOUR_PRODUCTION_KEY_HERE

# ============================================
# RESEND EMAIL SERVICE (Production)
# ============================================
# Get API key from Resend Dashboard:
# https://resend.com → API Keys → Create Production Key

# Resend API Key (starts with re_)
VITE_RESEND_API_KEY=re_your_production_api_key_here_do_not_expose

# Email sender address (must be verified domain)
# This should be a verified sender in Resend
VITE_EMAIL_FROM=noreply@solartrack.com

# Email batching configuration
# Number of emails to send in one batch
VITE_EMAIL_BATCH_SIZE=10

# Maximum retry attempts for failed emails
VITE_MAX_EMAIL_RETRIES=3

# Delay between retry attempts (in milliseconds)
# Default: 3600000 = 1 hour
VITE_EMAIL_RETRY_DELAY_MS=3600000

# ============================================
# EMAIL LOG RETENTION (Optional)
# ============================================

# How many days to keep email logs (default: 90)
VITE_EMAIL_LOG_RETENTION_DAYS=90

# ============================================
# SUPPORT CONTACT (Optional)
# ============================================

# Support email for customer references
VITE_SUPPORT_EMAIL=support@solartrack.com

# Support phone for customer references
VITE_SUPPORT_PHONE=+1-800-123-4567

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Environment identifier
VITE_APP_ENV=production

# Logging level (error, warn, info, debug)
VITE_LOG_LEVEL=error

# API request timeout in milliseconds
VITE_API_TIMEOUT_MS=30000

# ============================================
# SECURITY NOTES
# ============================================
#
# DO NOT:
# - Commit this file with real keys to git
# - Share API keys in chat, email, or documents
# - Use development keys in production
# - Expose RESEND_API_KEY to client code
#
# DO:
# - Store keys in secure vault (AWS Secrets Manager, HashiCorp Vault, etc.)
# - Rotate keys every 90 days (Resend) or 6 months (Supabase)
# - Use different keys for staging and production
# - Monitor key usage for unusual patterns
#
# ============================================
# VALIDATION CHECKLIST
# ============================================
#
# Before deployment verify:
# [ ] VITE_SUPABASE_URL is production URL (not staging)
# [ ] VITE_SUPABASE_ANON_KEY is production key (not staging)
# [ ] VITE_RESEND_API_KEY is production key (not test key)
# [ ] VITE_EMAIL_FROM is verified sender domain
# [ ] All required variables are set (no empty values)
# [ ] No test/dummy values left in configuration
# [ ] .gitignore includes .env.production
# [ ] .env.production.example has placeholder values only
#
# ============================================
